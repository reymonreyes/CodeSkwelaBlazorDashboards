@page "/"
@inject IVersionProvider VersionProvider
<Heading Size="HeadingSize.Is1" Margin="Margin.Is3.FromBottom">Blazorise Dashboard</Heading>

<Row HorizontalGutter="10" VerticalGutter="30">
    <Column ColumnSize="ColumnSize.Is4">
        <Card Background="Background.Success" WhiteText>
            <CardBody>                
                <CardText>
                    Total Sales
                </CardText>                
            </CardBody>
        </Card>
    </Column>
    <Column ColumnSize="ColumnSize.Is4">
        <Card Background="Background.Primary" WhiteText>
            <CardBody>
                <CardText>
                    Total Orders
                </CardText>
            </CardBody>
        </Card>
    </Column>
    <Column ColumnSize="ColumnSize.Is4">
        <Card Background="Background.Warning" WhiteText>
            <CardBody>
                <CardText>
                    Total Total Shipped
                </CardText>
            </CardBody>
        </Card>
    </Column>
</Row>
<Row HorizontalGutter="10" VerticalGutter="30">
    <Column ColumnSize="ColumnSize.Is6">
        <Card Background="Background.Success" WhiteText>
            <CardBody>
                <CardText>
                    Monthly Sales YTD
                </CardText>
            </CardBody>
        </Card>
    </Column>
    <Column ColumnSize="ColumnSize.Is6">
        <Card Background="Background.Success" WhiteText>
            <CardBody>
                <CardText>
                    Monthly Orders Made/Orders Shipped YTD
                </CardText>
            </CardBody>
        </Card>
    </Column>
</Row>
<Row HorizontalGutter="10" VerticalGutter="30">
    <Column ColumnSize="ColumnSize.Is3">
        <Card Background="Background.Success" WhiteText>
            <CardBody>
                <CardText>
                    Product Categories
                </CardText>
            </CardBody>
        </Card>
    </Column>
    <Column ColumnSize="ColumnSize.Is4">
        <Card Background="Background.Primary" WhiteText>
            <CardBody>
                <CardText>
                    Top 10 Products
                </CardText>
            </CardBody>
        </Card>
    </Column>
    <Column ColumnSize="ColumnSize.Is5">
        <Card Background="Background.Warning" WhiteText>
            <CardBody>
                <CardText>
                    Top 10 Customers
                </CardText>
            </CardBody>
        </Card>
    </Column>
</Row>